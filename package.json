{
  "name": "self-destructing-cache",
  "version": "3.0.1",
  "description": "An extension which deletes cookies and cache after closing a site.",
  "keywords": [
    "chrome",
    "self-destructing",
    "cache",
    "cookies",
    "data"
  ],
  "main": "background.js",
  "type": "module",
  "author": "Geert Eltink",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/geerteltink/self-destructing-cache/issues"
  },
  "homepage": "https://github.com/geerteltink/self-destructing-cache#readme",
  "private": true,
  "scripts": {
    "dev:chrome": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "npm run build:chrome && npm run build:firefox && npm run build:edge",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "npm run zip:chrome && npm run zip:firefox && npm run zip:edge",
    "zip:chrome": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "prettier": "npx prettier **/*.{md,json,js,ts} --write --list-different",
    "oxlint": "oxlint --config=.oxlintrc.json --ignore-path=.oxlintignore",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@wxt-dev/module-vue": "^1.0.3",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7",
    "wxt": "^0.20.25"
  }
}
